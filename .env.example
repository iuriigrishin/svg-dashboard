# Скопируйте в .env и заполните. .env в git не попадает (см. .gitignore).

# ── Google Sheets ──────────────────────────────────────────────
TEMPLATE_SPREADSHEET_ID=1w8uQB5kV-sm4RwQn9pklil1PVPdCvMwV8dlKlGaySOw
TARGET_SPREADSHEET_ID=1bGDO4seSBZSIpQ4OfGC02jq0r8OrHAQCTULhdnd5oa8
GOOGLE_APPLICATION_CREDENTIALS=service_account.json

# Сколько команд в каждой лиге (должно быть чётным)
JUN_TEAMS=20
MID_TEAMS=10
PRO_TEAMS=8

# Значения в ячейке счёта, которые означают "задача закрыта"
ALLOWED_SCORE_VALUES=5,8,12

# ── Apps Script (clasp) ──────────────────────────────────────────
# Project Settings → Script ID в редакторе script.google.com
APPSCRIPT_SCRIPT_ID=
# Заполняется после первого деплоя (appsscript/deploy.py подскажет значение)
APPSCRIPT_DEPLOYMENT_ID=
APPSCRIPT_CACHE_TTL=60
APPSCRIPT_VERSION_CACHE_TTL=30

# ── Cloudflare Worker (wrangler) ─────────────────────────────────
CF_ACCOUNT_ID=
CF_WORKER_NAME=blue-shape-5fbb
WORKER_CACHE_TTL=5
WORKER_STALE_TTL=60
# Публичный адрес воркера — provision.py перезапишет это значение после деплоя
WORKER_URL=https://blue-shape-5fbb.iurkagrishin187.workers.dev
